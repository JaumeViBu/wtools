{
  "name": "writing_tools",
  "version": "0.5.1",
  "description": "A command-line application which lets the user choose and use from a list of writing tools",
  "exports": "./bin/wtools.js",
  "type": "module",
  "imports": {
    "#commands/*": "./src/commands/*.js",
    "#utils/*": "./src/utils/*.js",
    "#bin/*": "./bin/*.js",
    "#root/*": "./*.json"
  },
  "bin": {
    "wtools": "./bin/wtools.js"
  },
  "scripts": {
    "preinstall": "only-allow pnpm",
    "start": "node bin/wtools.js",
    "test": "vitest"
  },
  "keywords": [],
  "author": "Jaume Vidal Buenafuente",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "only-allow": "^1.2.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^10.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10.0.0"
  }
}