{
    "name": "writing_tools",
    "version": "0.6.4",
    "description": "A command-line application which lets the user choose and use from a list of writing tools",
    "exports": "./bin/wtools.js",
    "type": "module",
    "imports": {
        "#commands/*": "./src/commands/*.js",
        "#utils/*": "./src/utils/*.js",
        "#bin/*": "./bin/*.js",
        "#root/*": "./*.json"
    },
    "bin": {
        "wtools": "./bin/wtools.js"
    },
    "scripts": {
        "preinstall": "only-allow pnpm",
        "start": "node bin/wtools.js",
        "test": "vitest",
        "biome": "pnpx @biomejs/biome check",
        "biome-w": "pnpx @biomejs/biome check --write",
        "biome-format": "pnpx @biomejs/biome format",
        "biome-format-w": "pnpx @biomejs/biome format --write",
        "biome-lint": "pnpx @biomejs/biome lint",
        "biome-lint-w": "pnpx @biomejs/biome lint --write",
        "publishOnly": "pnpm test"
    },
    "keywords": [
        "writing",
        "tags",
        "cli",
        "extract"
    ],
    "author": "Jaume Vidal Buenafuente",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/JaumeViBu/wtools.git"
    },
    "bugs": {
        "url": "https://github.com/JaumeViBu/wtools/issues"
    },
    "homepage": "https://github.com/JaumeViBu/wtools#readme",
    "files": [
        "bin/",
        "src/",
        "README.md",
        "LICENSE"
    ],
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "only-allow": "^1.2.2",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "@rolldown/binding-linux-x64-gnu": "1.0.2",
        "commander": "^14.0.3"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=20",
            "onFail": "error"
        },
        "packageManager": {
            "name": "pnpm",
            "version": ">=10.0.0",
            "onFail": "error"
        }
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=10.0.0"
    }
}
