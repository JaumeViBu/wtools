{
    "name": "writing_tools",
    "version": "0.5.1",
    "description": "A command-line application which lets the user choose and use from a list of writing tools",
    "exports": "./bin/wtools.js",
    "type": "module",
    "imports": {
        "#commands/*": "./src/commands/*.js",
        "#utils/*": "./src/utils/*.js",
        "#bin/*": "./bin/*.js",
        "#root/*": "./*.json"
    },
    "bin": {
        "wtools": "./bin/wtools.js"
    },
    "scripts": {
        "preinstall": "only-allow pnpm",
        "start": "node bin/wtools.js",
        "test": "vitest",
        "biome": "pnpx @biomejs/biome check",
        "biome-w": "pnpx @biomejs/biome check --write",
        "biome-format": "pnpx @biomejs/biome format",
        "biome-format-w": "pnpx @biomejs/biome format --write",
        "biome-lint": "pnpx @biomejs/biome lint",
        "biome-lint-w": "pnpx @biomejs/biome lint --write"
    },
    "keywords": [],
    "author": "Jaume Vidal Buenafuente",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "only-allow": "^1.2.2",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "commander": "^14.0.3"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "onFail": "error"
        },
        "packageManager": {
            "name": "pnpm",
            "version": ">=10.0.0",
            "onFail": "error"
        }
    },
    "engines": {
        "node": ">=18",
        "pnpm": ">=10.0.0"
    },
    "pnpm": {
        "overrides": {
            "vite": ">=8.0.5"
        }
    }
}